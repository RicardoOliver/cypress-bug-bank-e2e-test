{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "types": ["cypress", "node"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@actions/*": ["cypress/actions/*"],
      "@utils/*": ["cypress/utils/*"]
    }
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"]
}