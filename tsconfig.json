{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["cypress", "node"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@actions/*": ["./cypress/actions/*"],
      "@utils/*": ["./cypress/utils/*"]
    }
  },
  "include": ["cypress/**/*.ts", "cypress.config.ts"]
}