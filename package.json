{
  "name": "cypress-bug-bank-e2e-test",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade Cypress + k6 automation platform",
  "scripts": {
    "lint": "eslint . --ext .js",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test app/**/*.test.js",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:smoke": "cypress run --expose grepTags=@smoke --record false",
    "cy:run:critical": "cypress run --expose grepTags=@critical --record false",
    "cy:cloud": "cypress run --record --parallel --group e2e-chrome",
    "quality:gates": "bash ci/quality-gates.sh",
    "k6:load": "k6 run --summary-export=artifacts/k6-load-summary.json k6/load.js",
    "k6:stress": "k6 run --summary-export=artifacts/k6-stress-summary.json k6/stress.js",
    "k6:spike": "k6 run --summary-export=artifacts/k6-spike-summary.json k6/spike.js"
  },
  "engines": {
    "node": ">=26"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "cypress": "16.5.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^5.1.1",
    "typescript": "^5.9.2",
    "@eslint/js": "^9.35.0",
    "@cypress/grep": "^4.0.4"
  },
  "dependencies": {
    "express": "^4.21.2"
  }
}
